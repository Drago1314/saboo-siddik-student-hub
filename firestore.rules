rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidNote(data) {
      return data.title is string && data.title.size() <= 100 &&
             data.subject is string && data.subject.size() <= 50 &&
             data.semester is int && data.semester >= 1 && data.semester <= 8 &&
             data.content is string && data.content.size() <= 10000;
    }

    match /notes/{noteId} {
      allow read: if true; // Public access for students
      allow create: if isSignedIn() && isValidNote(request.resource.data);
      allow update, delete: if false; // For now, only admin or special rules (not implemented yet)
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
